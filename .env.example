DATABASE_URL="file:./data/subtracker.db"

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=your_password_here
JWT_SECRET=your_jwt_secret_here


# DingTalk Robot (optional, can also configure in settings page)
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# Email SMTP (optional, can also configure in settings page)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Default settings
NEXT_PUBLIC_DEFAULT_CURRENCY=CNY
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh
TZ=Asia/Shanghai
